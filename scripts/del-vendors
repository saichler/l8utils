#!/bin/bash

# Find all vendor directories under current location
VENDOR_DIRS=$(find . -type d -name "vendor" 2>/dev/null)

if [ -z "$VENDOR_DIRS" ]; then
    echo "No vendor directories found."
    exit 0
fi

echo "The following vendor directories will be deleted:"
echo "$VENDOR_DIRS"
echo ""

read -p "Are you sure you want to delete these directories? (y/N): " confirm

if [[ "$confirm" =~ ^[Yy]$ ]]; then
    find . -type d -name "vendor" -exec rm -rf {} + 2>/dev/null
    echo "Vendor directories deleted."
else
    echo "Operation cancelled."
fi
